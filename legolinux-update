#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# superuser ////////////////////////////////////////////////////////////////////

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="01-04-2022"

# usage ///////////////////////////////////////////////////////////////////////

while (($#))
do
	case "${1}" in
		-directory)
			directory="${2}"

			shift
		;;

		-a|--all)
			option="all"
		;;

		-e|--export)
			option="exports"
		;;

		-r|--render)
			option="renders"
		;;

		-m|--models)
			option="models"
		;;

		-b|--background)
			option="background"
		;;

		-d|--drawer)
			option="drawer"
		;;

		-n|--menu)
			option="menu"
		;;

		-v|--viewer)
			option="viewer"
		;;

		-h|--help)
			echo
			echo -e "Usage: ./${script} [EXTENSION] | [OPTION] [PARAMETER]"
			echo
			echo -e "Utility options:"
			echo
			echo -e "-directory             Specify directory to load models from."
			echo
			echo -e "-a, --all              Full website framework and content update."
			echo
			echo -e "-e, --exports          Models exports content update."
			echo -e "-r, --renders          Models renders content update."
			echo -e "-m, --models           Models content update."
			echo -e "-b, --background       Background content update."
			echo -e "-d, --drawer           Drawer content update."
			echo -e "-n, --menu             Models menu content update."
			echo -e "-v, --viewer           Models viewer content update."
			echo
			echo -e "'${script}'       [ Version ${version} ]"
			echo

			exit
		;;

		"")
			# handle empty argument:
			# use default values specified in script

			:
		;;

		*)
			echo
			echo -e "Usage: ./${script} [EXTENSION] | [OPTION] [PARAMETER]"
			echo
			echo -e "${script}: Unknown option '${1}'"
			echo -e "Type './${script} --help' for help and usage information."
			echo

			exit 1

		;;

		esac

		shift
done

# clear ////////////////////////////////////////////////////////////////////////

frobulator.clear

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"
echo

# variables ////////////////////////////////////////////////////////////////////

# defaults /////////////////////////////////////////////////////////////////////

# functions ////////////////////////////////////////////////////////////////////

upload () {
	git add *

	git commit		\
		--all		\
		--message='Models update'

	git push > /dev/null 2>&1
}

option () {
	selection="${1}"

	if [[ -n "${#list[@]}" ]]
	then
		# ${2} - array

		list=(${@:2})
	else
		script="${2}"

		list=()

		list+=("${script}")
	fi

	if [[ "${option}" = "${selection}" ]]
	then
		for script in ${list[@]}
		do
			bash ./"${script}"
		done
	fi

	upload &

	frobulator.progress "Updating" "[ ${selection} ]"
	echo

	list=()
}

# requirements /////////////////////////////////////////////////////////////////

list=(
	git
	rsync
)

frobulator.assess ${list[@]}

list=()

# update ///////////////////////////////////////////////////////////////////////


if [[ "${option}" = "all" ]]
then
	option all
fi

if [[ "${option}" = "exports" ]]
then
	option exports
fi

if [[ "${option}" = "renders" ]]
then
	option renders
fi

if [[ "${option}" = "models" ]]
then
	option models
fi

if [[ "${option}" = "background" ]]
then
	option background
fi

if [[ "${option}" = "drawer" ]]
then
	option drawer
fi

if [[ "${option}" = "menu" ]]
then
	option menu
fi

if [[ "${option}" = "viewer" ]]
then
	option viewer
fi

frobulator.scs "Update" "[ Done ]"
echo
