						<instance_material symbol="Main_Colour" target="#Light_Bluish_Grey-material"/>
					</technique_common>
				</bind_material>
			</instance_geometry>
		</node>
	</visual_scene>
</library_visual_scenes>
<scene>
	<instance_visual_scene url="#DefaultScene"/>
</scene>
</COLLADA>
