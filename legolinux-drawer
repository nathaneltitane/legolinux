#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# superuser ////////////////////////////////////////////////////////////////////

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="02-08-2023"

# usage ////////////////////////////////////////////////////////////////////////

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"
echo

# variables ////////////////////////////////////////////////////////////////////

stamp=$(date +"%m-%d-%Y")

# defaults /////////////////////////////////////////////////////////////////////

# functions ////////////////////////////////////////////////////////////////////

frobulator.inf "Generating model entries"
echo

frobulator.fwd "Writing..."
echo

# generate header

cat << MODEL-DRAWER-HEADER -> "modules/drawer.html"
<!-- scripts -->

<script src="/javascript/drawer.js" type="text/javascript"></script>

<script src="/javascript/year.js" type="text/javascript"></script>

<!-- drawer -->

<div class="drawer">

	<div class="drawer-button cursor-cell">

		<div class="icon icon-64 logo-drawer"></div>

	</div>

	<div class="flex flex-column flex-stretch">

		<!-- legend -->

		<div class="list section notice">

			<div class="flex flex-column flex-middle">

				<div class="flex-cell text-bold text-center">

					// NOTICE //</br>

					</br>

				</div>

				<div class="flex-cell text-center">

					INSTRUCTIONS ARE MADE AVAILABLE PROGRESSIVELY:</br>

					</br>

					PURCHASING AN INSTRUCTION SET PRIORITIZES AVAILABILITY FOR THAT MODEL!</br>

					FEEL FREE TO <label for="modal-contact" class="cursor-pointer text-bold">// CONTACT //</label> ABOUT INQUIRIES ABOUT A SPECIFIC MODEL!</br>

					</br>

				</div>

				<div class="flex-cell text-bold text-center">

					THANK YOU FOR YOUR SUPPORT!</br>

				</div>

			</div>

		</div>

		<!-- instructions available -->

		<div class="list section available">

			<div class="flex flex-row flex-middle">

				<div class="flex">

					<div class="icon icon-flex icon-center logo-green"></div>

				</div>

				<div class="flex-cell text-center">

					AVAILABLE

				</div>

			</div>

		</div>

		<!-- instructions progress -->

		<div class="list section progress">

			<div class="flex flex-row flex-middle">

				<div class="flex">

					<div class="icon icon-flex icon-center logo-orange"></div>

				</div>

				<div class="flex-cell text-center">

					IN PROGRESS

				</div>

			</div>

		</div>

		<!-- models -->

MODEL-DRAWER-HEADER

# values

extensions_list+=(
	png
)

for extension in ${extensions_list[@]}
do
	count=1

	# shuffle models directories list:
	# generates sorted showcase of all models on each update

	for models_list in $(find models/ -type f -iname flat."${extension}" | sort)
	do
		IFS='/' read -r -a path <<< $(echo "$models_list")

		# /models/model-type/model/renders/render-type/render.${extension}

		# "${path[0]}" /models
		# "${path[1]}" /model-category
		# "${path[2]}" /model
		# "${path[3]}" /renders

		# render types:

		# "${path[4]}" /outine
		# "${path[4]}" /flat
		# "${path[4]}" /thumbnail

		# "${path[5]}" /render.extension

		model_category=$(cat ${path[0]}/${path[1]}/title)

		model_title=$(cat ${path[0]}/${path[1]}/${path[2]}/title)

		model_title_string=$(echo ${model_title//\<\/\br\>/})

		model_paypal=${path[0]}/${path[1]}/${path[2]}/paypal

		model_paypal_id=$(cat ${path[0]}/${path[1]}/${path[2]}/paypal)

		model_pieces=${path[0]}/${path[1]}/${path[2]}/pieces

		model_pieces_count=$(cat ${path[0]}/${path[1]}/${path[2]}/pieces)

		model_instructions=${path[0]}/${path[1]}/${path[2]}/instructions

		model_instructions_price=$(cat ${path[0]}/${path[1]}/${path[2]}/price)

# generate model drawer entries

if [ ! -f models/"${path[1]}"/todo ]
then

cat << MODEL-DRAWER-CONTENT ->> "modules/drawer.html"
		<div class="list section">

			<div class="flex flex-column flex-stretch">

				<div class="flex-cell category">

					${model_category}

				</div>

				<a class="container" href="/models/${path[1]}/${path[2]}/">

					<div class="flex flex-row flex-middle">

						<div class="flex-cell-start">

							<div class="icon icon-flex icon-center logo-green"></div>

						</div>

						<div class="flex-cell text-center">

							<img src="/${path[0]}/${path[1]}/${path[2]}/${path[3]}/thumbnail/thumbnail.png" />

						</div>

					</div>


					<div class="flex flex-column flex-middle">

						<div class="flex-cell text-center">

							${model_title}

						</div>

						<div class="flex-cell text-center">

							${model_pieces_count} PIECES

						</div>

					</div>

				</a>

			</div>

		</div>

MODEL-DRAWER-CONTENT

else

cat << MODEL-DRAWER-CONTENT ->> "modules/drawer.html"
		<div class="list section">

			<div class="flex flex-column flex-stretch">

				<div class="flex-cell category">

					${model_category}

				</div>

				<a class="container" href="/models/${path[1]}/${path[2]}/">

					<div class="flex flex-row flex-middle">

						<div class="flex-cell-start">

							<div class="icon icon-flex icon-center logo-orange"></div>

						</div>

						<div class="flex-cell">

							<img src="/${path[0]}/${path[1]}/${path[2]}/${path[3]}/thumbnail/thumbnail.png" />

						</div>

					</div>


					<div class="flex flex-column flex-middle">

						<div class="flex-cell text-center">

							${model_title}

						</div>

						<div class="flex-cell text-center">

							${model_pieces_count} PIECES

						</div>

					</div>

				</a>

			</div>

		</div>

MODEL-DRAWER-CONTENT

fi

	((count++))

	done
done

# generate footer

cat << MODEL-DRAWER-FOOTER ->> "modules/drawer.html"
		<!-- copyright -->

		<div class="list section copyright">

			<div class="flex flex-column flex-center flex-middle">

				<div class="flex">

					<div class="avatar avatar-128" href=""></div>

				</div>

			</div>

			<div class="flex flex-column flex-center flex-middle">

				<div class="flex-cell text-center">

					Version // 12-07-2022</br>
					Lego // Linux - Where Lego meets Linux</br>
					N Λ T H Λ N E L - ©  <text id="year"></text>

				</div>

			</div>

		</div>

	</div>

</div>

MODEL-DRAWER-FOOTER

frobulator.inf "Models" "[ ${count} ]"
echo

frobulator.scs "Done" "[ Drawer ]"
echo
