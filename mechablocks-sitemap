#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [ -f "${HOME}"/.local/bin/frobulator ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator
fi

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# superuser ////////////////////////////////////////////////////////////////////

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="06-04-2026"

# usage ////////////////////////////////////////////////////////////////////////

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# variables ////////////////////////////////////////////////////////////////////
site_url='https://mechablocks.com'

output_file='sitemap.xml'

site_url="${site_url%/}"

# functions ////////////////////////////////////////////////////////////////////

sitemap_add_url () {

	local url_path="${1}"
	local file_path="${2}"
	local modified_date

	url_path="${url_path#./}"
	url_path="${url_path#index.html}"
	url_path="${url_path%index.html}"
	url_path="${url_path%/}"

	if [ "${url_path}" = "." ] ||
	   [ "${url_path}" = ""  ]
	then
		url_path="/"
	else
		url_path="/${url_path}/"
	fi

	url_path="${url_path//\/\//\/}"

	modified_date="$(date -u -r "${file_path}" '+%Y-%m-%d')"

	cat >> "${output_file}" << EOF

	<url>

		<loc>${site_url}${url_path}</loc>

		<lastmod>${modified_date}</lastmod>

		<changefreq>weekly</changefreq>

		<priority>0.80</priority>

	</url>
EOF

	(( page_count++ ))

}

# initialize

page_count=0

# header

cat >> "${output_file}" << EOF
<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
EOF

# homepage /////////////////////////////////////////////////////////////////////

if [ -f './index.html' ]
then
	sitemap_add_url './index.html' './index.html'
fi

# crawl index pages /////////////////////////////////////////////////////////////

while IFS= read -r file_path
do
	if [ "${file_path}" = './index.html' ] ||
	   [[ "${file_path}" == ./modules/* ]] ||
	   [[ "${file_path}" == ./logo/*    ]] ||
	   [[ "${file_path}" == ./assets/*  ]] ||
	   [[ "${file_path}" == ./images/*  ]] ||
	   [[ "${file_path}" == ./renders/* ]]
	then
		continue
	fi

	sitemap_add_url "${file_path}" "${file_path}"

done < <( find . -type f -name 'index.html' | sort )

# crawl model folders ///////////////////////////////////////////////////////////

if [ -d './models' ]
then
	while IFS= read -r directory_path
	do
		if [ -f "${directory_path}/index.html" ]
		then
			continue
		fi

		if [ -f "${directory_path}/model.dae"        ] ||
		   [ -f "${directory_path}/model.glb"        ] ||
		   [ -f "${directory_path}/model.gltf"       ] ||
		   [ -f "${directory_path}/instructions.pdf" ] ||
		   [ -d "${directory_path}/renders"          ]
		then
			sitemap_add_url "${directory_path}" "${directory_path}"
		fi

	done < <( find ./models -mindepth 2 -maxdepth 2 -type d | sort )
fi

# footer

cat >> "${output_file}" << EOF

</urlset>
EOF

# report ///////////////////////////////////////////////////////////////////////

echo "sitemap written: ${output_file}"
echo "urls written: ${page_count}"

if [ "${page_count}" -eq 0 ]
then
	frobulator.err "No URLs found" "[ '${site_url}' ]"
	echo

	frobulator.wrn "Script must be run from site root directory."
	echo
fi
