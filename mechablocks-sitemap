#!/bin/bash

# variables ////////////////////////////////////////////////////////////////////

site_url='https://mechablocks.com'

output_file='sitemap.xml'

site_url="${site_url%/}"

script_directory="$(cd "$(dirname "${0}")" && pwd)"

# functions ////////////////////////////////////////////////////////////////////

sitemap_add_url () {

	local url_path="${1}"
	local file_path="${2}"
	local modified_date

	url_path="${url_path#./}"
	url_path="${url_path#index.html}"
	url_path="${url_path%index.html}"
	url_path="${url_path%/}"

	if [ "${url_path}" = "." ] ||
	   [ "${url_path}" = ""  ]
	then
		url_path="/"
	else
		url_path="/${url_path}/"
	fi

	url_path="${url_path//\/\//\/}"

	modified_date="$(date -u -r "${file_path}" '+%Y-%m-%d')"

	cat >> "${output_file}" << EOF

	<url>

		<loc>${site_url}${url_path}</loc>

		<lastmod>${modified_date}</lastmod>

		<changefreq>weekly</changefreq>

		<priority>0.80</priority>

	</url>
EOF

	(( page_count++ ))

}

# initialize

cd "${script_directory}" || exit 1

> "${output_file}"

page_count=0

# header

cat >> "${output_file}" << EOF
<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
EOF

# url

# homepage /////////////////////////////////////////////////////////////////////

if [ -f './index.html' ]
then
	sitemap_add_url './index.html' './index.html'
fi

# crawl index pages /////////////////////////////////////////////////////////////

while IFS= read -r file_path
do
	if [ "${file_path}" = './index.html' ] ||
	   [[ "${file_path}" == ./modules/* ]] ||
	   [[ "${file_path}" == ./logo/* ]] ||
	   [[ "${file_path}" == ./assets/* ]] ||
	   [[ "${file_path}" == ./images/* ]] ||
	   [[ "${file_path}" == ./renders/* ]]
	then
		continue
	fi

	sitemap_add_url "${file_path}" "${file_path}"

done < <( find . -type f -name 'index.html' | sort )

# crawl model folders ///////////////////////////////////////////////////////////

if [ -d './models' ]
then
	while IFS= read -r directory_path
	do
		if [ -f "${directory_path}/index.html" ]
		then
			continue
		fi

		if [ -f "${directory_path}/model.dae"        ] ||
		   [ -f "${directory_path}/model.glb"        ] ||
		   [ -f "${directory_path}/model.gltf"       ] ||
		   [ -f "${directory_path}/instructions.pdf" ] ||
		   [ -d "${directory_path}/renders"          ]
		then
			sitemap_add_url "${directory_path}" "${directory_path}"
		fi

	done < <( find ./models -mindepth 2 -maxdepth 2 -type d | sort )
fi

# footer

cat >> "${output_file}" << EOF

</urlset>
EOF

# report ///////////////////////////////////////////////////////////////////////

echo "sitemap written: ${output_file}"
echo "urls written: ${page_count}"

if [ "${page_count}" -eq 0 ]
then
	echo "warning: no urls found"
	echo "make sure this script is running from the site root"
	echo "expected: ./index.html and/or ./models/category/model-name"
fi
