#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [ -f "${HOME}"/.local/bin/frobulator ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator
fi

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="06-04-2026"

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# configuration ////////////////////////////////////////////////////////////////

address_site='https://mechablocks.com'
output_sitemap='sitemap.xml'

directories_exclude_list=(
	'./.git/'
	'./.github/'
	'./node_modules/'
	'./modules/'
	'./logo/'
	'./assets/'
	'./images/'
	'./renders/'
	'./exports/'
)

# defaults /////////////////////////////////////////////////////////////////////

url_site="${address_site%/}"

page_count=0

# functions ////////////////////////////////////////////////////////////////////

directory_excluded_check () {

	file_path="${1}"

	for directory_path in "${directories_exclude_list[@]}"
	do
		if [[ "${file_path}" == "${directory_path}"* ]]
		then
			return 0
		fi
	done

	return 1

}

url_index () {

	url_path="${1}"
	file_path="${2}"

	url_path="${url_path#./}"
	url_path="${url_path#index.html}"
	url_path="${url_path%index.html}"
	url_path="${url_path%/}"

	if [ "${url_path}" = "." ] ||
	   [ "${url_path}" = ""  ]
	then
		url_path="/"
	else
		url_path="/${url_path}/"
	fi

	url_path="${url_path//\/\//\/}"

	date_modified="$(date -u -r "${file_path}" '+%Y-%m-%d')"

	frequency_change="weekly"

	cat >> "${output_sitemap}" << URL

	<url>

		<loc>${url_site}${url_path}</loc>

		<lastmod>${date_modified}</lastmod>

		<changefreq>${frequency_change}</changefreq>

		<priority>0.80</priority>

	</url>
URL

	(( page_count++ ))

}

# initialize ///////////////////////////////////////////////////////////////////

frobulator.fwd "Writing..."
echo

cat > "${output_sitemap}" << HEADER
<?xml version="1.0" encoding="UTF-8"?>

<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
HEADER

# crawl index pages /////////////////////////////////////////////////////////////

IFS=$'\n'

index_files=$(find . -type f -name 'index.html' | sort)

for file_path in ${index_files}
do
	if directory_excluded_check "${file_path}"
	then
		continue
	fi

	url_index "${file_path}" "${file_path}"
done

unset IFS

# write footer /////////////////////////////////////////////////////////////////

cat >> "${output_sitemap}" << FOOTER

</urlset>
FOOTER

# report ///////////////////////////////////////////////////////////////////////

if [ "${page_count}" -eq 0 ]
then
	frobulator.err "No URLs found" "[ ${url_site} ]"
	echo

	frobulator.wrn "Script must be run from site root directory."
	echo

	exit 1
else
	frobulator.inf "Sitemap written" "[ ${output_sitemap} ]"
	echo

	frobulator.inf "URL count" "[ ${page_count} ]"
	echo

	frobulator.cpt "Complete" "[ Sitemap ]"
fi
